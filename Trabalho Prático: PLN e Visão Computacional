        "#Exemplo 1 - Processamento de Linguagem Natural (PLN)\n",
        "import spacy\n",
        "from textblob import TextBlob\n",
        "\n",
        "nlp = spacy.load(\"pt_core_news_sm\")\n",
        "texto_exemplo = (\n",
        "    \"A Google inaugurou um novo escritório incrível em São Paulo ontem. \"\n",
        "    \"O atendimento deles é fantástico e a estrutura é absolutamente maravilhosa!\"\n",
        ")\n",
        "\n",
        "print(\"--- EXECUTANDO PROCESSAMENTO DE LINGUAGEM NATURAL ---\\n\")\n",
        "print(f\"Texto analisado: '{texto_exemplo}'\\n\")\n",
        "\n",
        "\n",
        "doc = nlp(texto_exemplo)\n",
        "print(\"📌 Entidades Nomeadas Encontradas:\")\n",
        "for ent in doc.ents:\n",
        "    print(f\"- Entidade: {ent.text} | Categoria: {ent.label_}\")\n",
        "\n",
        "print(\"\\n\" + \"=\"*40 + \"\\n\")\n",
        "\n",
        "analysis = TextBlob(texto_exemplo)\n",
        "\n",
        "polaridade = analysis.sentiment.polarity\n",
        "\n",
        "print(\"📊 Análise de Sentimento:\")\n",
        "print(f\"Polaridade calculada: {polaridade}\")\n",
        "if polaridade > 0:\n",
        "    print(\"Resultado: Sentimento Positivo 😊\")\n",
        "elif polaridade < 0:\n",
        "    print(\"Resultado: Sentimento Negativo 😞\")\n",
        "else:\n",
        "    print(\"Resultado: Sentimento Neutro 😐\")"
      ],
