        "import cv2\n",
        "import numpy as np\n",
        "from skimage import data  # Usaremos uma imagem de teste nativa do Python\n",
        "from google.colab.patches import cv2_imshow  # Função exclusiva do Colab para mostrar imagens\n",
        "\n",
        "print(\"--- EXECUTANDO VISÃO COMPUTACIONAL (OTSU) ---\\n\")\n",
        "\n",
        "# 1. Carregar uma imagem de teste famosa (as moedas) nativa do scikit-image\n",
        "# Ela já vem em escala de cinza por padrão\n",
        "img_cinza = data.coins()\n",
        "\n",
        "# 2. Aplicar a Limiarização pelo Método de Otsu\n",
        "# O Otsu encontra o corte perfeito entre o fundo (escuro) e as moedas (claras)\n",
        "limiar_calculado, img_binarizada = cv2.threshold(\n",
        "    img_cinza, 0, 255, cv2.THRESH_BINARY + cv2.THRESH_OTSU\n",
        ")\n",
        "\n",
        "print(f\"O algoritmo de Otsu definiu o limiar ideal em: {limiar_calculado}\\n\")\n",
        "\n",
        "# 3. Exibir os resultados lado a lado no Colab\n",
        "print(\"Esquerda: Imagem Original (Moedas) | Direita: Resultado de Otsu (Preto e Branco Puro)\")\n",
        "resultado_lado_a_lado = np.hstack((img_cinza, img_binarizada))\n",
        "cv2_imshow(resultado_lado_a_lado)\n",
        "\n",
        "# 4. Salvar o resultado final para você baixar e colocar no GitHub se quiser\n",
        "cv2.imwrite('resultado_otsu.jpg', img_binarizada)"
      ],
